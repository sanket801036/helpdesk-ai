# =========================================================
#  Helpdesk AI — Environment Variables (EXAMPLE)
#  Copy this to `.env` and fill REAL values.
#  ⚠️  NEVER commit the real .env — it's in .gitignore.
# =========================================================

# ─── App ─────────────────────────────────────────
APP_NAME=Helpdesk AI
APP_ENV=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173

# ─── Database (PostgreSQL + pgvector) ────────────
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=helpdesk
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://helpdesk:change_me_strong_password@db:5432/helpdesk

# ─── Redis ───────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ─── JWT / Security ──────────────────────────────
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI (Ollama) ─────────────────────────────────
AI_PROVIDER=ollama            # ollama | claude  (abstraction ke liye)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_DIM=768
# CLAUDE_API_KEY=            # sirf agar AI_PROVIDER=claude

# ─── Email (SMTP) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Helpdesk AI
SMTP_FROM_EMAIL=your_email@example.com

# ─── Frontend ────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000
