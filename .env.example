# =========================================================
#  Helpdesk AI — Environment Variables (EXAMPLE)
#  Copy this to `.env` and fill REAL values.
#  ⚠️  NEVER commit the real .env — it's in .gitignore.
# =========================================================

# ─── App ─────────────────────────────────────────
APP_NAME=Helpdesk AI
APP_ENV=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173

# ─── Database (MySQL) ────────────────────────────
# Format: mysql+aiomysql://USER:PASSWORD@HOST:PORT/DB?charset=utf8mb4
# Aapke laptop par (local): host = localhost
DATABASE_URL=mysql+aiomysql://erp_user:root@localhost:3306/erp?charset=utf8mb4

# ─── JWT / Security ──────────────────────────────
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI (Hugging Face Inference API) ─────────────
AI_PROVIDER=huggingface
HF_API_KEY=hf_your_api_key_here
HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_API_BASE=https://api-inference.huggingface.co
EMBEDDING_DIM=384

# ─── Frontend ────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000
